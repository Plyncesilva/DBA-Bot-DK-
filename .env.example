# Copy this file to .env and fill in values
# Never commit .env

# --- LLM mode ---
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1

# --- Files (optional overrides) ---
# If your headers file contains cookies/session tokens, keep it out of git and point to it here.
HEADERS_FILE=headers.json
MESSAGE_FILE=message.txt
